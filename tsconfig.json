{
  "compilerOptions": { // タイプスクリプトをどう変換するかの指定
    "target": "ES2017", // JSのバージョン
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true, // 厳密な型チェックを有効にする
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext", // JSのモジュール形式指定→環境に合わせて使い分け
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [ // どのファイルを型チェック対象にするか
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [ // 型チェックの対象から外すファイルやディレクトリ
    "node_modules",
    "supabase/functions"
  ]
}
